APP_NAME=AURA AI API
APP_ENV=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://aura:postgres@localhost:5433/aura_ai
FRONTEND_ORIGINS=http://localhost:5173

JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_SCREENING_ENABLED=true
AI_SCREENING_PROMPT_VERSION=v1
AI_SCREENING_CLIENT_MODE=REAL
OPENAI_REQUEST_TIMEOUT_SECONDS=90

GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_MAX_FILES=30
GITHUB_MAX_FILE_SIZE_BYTES=100000
GITHUB_MAX_TOTAL_CHARACTERS=120000
GITHUB_REQUEST_TIMEOUT_SECONDS=20

CV_UPLOAD_DIRECTORY=storage/cv
CV_MAX_FILE_SIZE_MB=10
CV_MAX_EXTRACTED_CHARACTERS=50000

SCREENING_STATUS_POLL_INTERVAL_MS=3000
